#include <iostream>
#include <vector>
using namespace std;

int partition(vector<int>& a, int l, int r) {
    int pivot = a[r];
    int i = l;

    for (int j = l; j < r; j++) {
        if (a[j] < pivot) {
            swap(a[i], a[j]);
            i++;
        }
    }

    swap(a[i], a[r]);
    return i;
}

void quickSort(vector<int>& a, int l, int r) {
    if (l >= r) return;

    int p = partition(a, l, r);
    quickSort(a, l, p - 1);
    quickSort(a, p + 1, r);
}

int main() {
    vector<int> a = {5,3,8,1,2};

    quickSort(a, 0, a.size() - 1);

    for (int x : a) cout << x << " ";
}
