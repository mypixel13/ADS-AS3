#include <unordered_map>
#include <iostream>
using namespace std;

int main() {
    int nums[] = {2, 7, 11, 15};
    int size=4;               
    int target = 9;
    
    unordered_map<int, int> map;
    
    for (int i = 0; i < size; i++) {
        int complement = target - nums[i];
        
        if (map.count(complement)) {
            cout << "[" << map[complement] << ", " << i << "]" << endl;
            return 0;
        }
        
        map[nums[i]] = i;
    }
    
    return 0;
}
