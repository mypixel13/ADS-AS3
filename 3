#include <iostream>
#include <unordered_map>
#include <string>
using namespace std;

bool Iso(string s, string t) {
    unordered_map<char,char> sMap, tMap;
    for (int i = 0; i < s.size(); i++) {
        char sc = s[i], tc = t[i];
        if (sMap.count(sc) && sMap[sc] != tc) return false;
        if (tMap.count(tc) && tMap[tc] != sc) return false;
        sMap[sc] = tc;
        tMap[tc] = sc;
    }
    return true;
}

int main() {
    cout << Iso("egg", "add") << "\n";  
    cout << Iso("foo", "bar") << "\n";  
    cout << Iso("paper", "title") << "\n"; 
    return 0;
}
