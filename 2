#include <unordered_map>
#include <string>
#include <iostream>
using namespace std;

int first(string s) {
    unordered_map<char, int> map;

  
    for (int i = 0; i < s.size(); i++) {
        map[s[i]]++; 
    }


    for (int i = 0; i < s.size(); i++) {
        if (map[s[i]] == 1) {
            return i;
        }
    }

    return -1; 
}

int main() {
    string s = "leetcode";
    cout << first(s) << endl; 

    s = "loveleetcode";
    cout << first(s) << endl; 

    return 0;
}
